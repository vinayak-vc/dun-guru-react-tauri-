# Kiosk development environment variable for API base URL
# For local dev, use Vite proxy to avoid CORS (see vite.config.ts)
VITE_API_BASE_URL=/api/

# Optional: API requires Bearer token (see Postman collection auth settings)
# VITE_API_BEARER_TOKEN=YOUR_TOKEN_HERE

# Kiosk development environment variable for target button ID
VITE_TARGET_BUTTON_ID=YOUR_TARGET_ID
