# Kiosk development environment variable for API base URL
# For local dev, use Vite proxy to avoid CORS (see vite.config.ts / vite.config.js)
VITE_API_BASE_URL=/api/

# Optional: API requires Bearer token (see Postman collection auth settings)
# VITE_API_BEARER_TOKEN=YOUR_TOKEN_HERE

# Home bundle: pick `response.data[i]` where `data[i].buttons[0]._id` matches (default is Sikh History)
# VITE_HOME_FIRST_BUTTON_ID=69a16102cef5996af9807c67
