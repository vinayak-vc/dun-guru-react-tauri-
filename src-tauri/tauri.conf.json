{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "com.dusguru.kiosk",
  "productName": "DusGuru",
  "version": "1.0.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "DusGuru",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "devtools": false
      }
    ]
  },
  "bundle": {
    "active": true
  },
  "plugins": {}
}